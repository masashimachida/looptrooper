# cp loop.yaml.example loop.yaml して非秘密の設定を書く。loop.yaml は gitignore 済み。
# 形式: 「ENV_VAR名: 値」のフラットなマップ（キーは環境変数名そのまま）。値は1行。
#   config.sh が yq でパースして環境変数に展開する（driver / poller / claude セッションが読む）。
#   優先順位: .env / compose の環境変数 > この loop.yaml > 既定値。
#   ※秘密（GitHub App 秘密鍵 / GH_TOKEN / Slack webhook / NOTIFY_CMD）は .env のまま。ここには書かない。
#   ※値に ": "(コロン+空白) や先頭記号が要るときは "..." で囲む。

# ── 対象リポジトリ ──
TARGET_REPO_URL: https://github.com/xxxx/xxxx.git
DEFAULT_BRANCH: main
# PR_BASE_BRANCH: develop      # PR の向き先（未設定なら DEFAULT_BRANCH）。作業ブランチもここから切る

# ── スタックコマンド（Verifier が回す。claude セッションに $TEST_CMD 等で継承）──
BUILD_CMD: npm run build
TEST_CMD: npm test
LINT_CMD: npm run lint
# 検証前に必ず1回走る環境準備（任意）。BUILD/TEST/LINT が依存する起動・依存導入・生成等を集約。
#   コンテナ内検証では node_modules 等が固定され、依存追加タスクは setup で入れ直さないとコケる。
#   待機は必ず timeout で頭打ち（無限待機ループ禁止）。例（node をコンテナで動かす構成）:
# VERIFY_SETUP_CMD: >-
#   docker compose up -d &&
#   timeout 90 bash -c 'until docker compose exec -T db pg_isready -U postgres; do sleep 2; done' &&
#   docker compose exec -T app npm ci &&
#   docker compose exec -T app npx prisma generate &&
#   docker compose exec -T app npx prisma migrate deploy
# ※ 上の例のように node もコンテナで動かす場合、BUILD/TEST/LINT は exec 形にする:
# BUILD_CMD: docker compose exec -T app npm run build
# TEST_CMD: docker compose exec -T app npm test
# LINT_CMD: docker compose exec -T app npm run lint
#
# タスク境界の後始末（任意・driver が成否/timeout/crash いずれでも必ず実行・cwd 非依存）。
#   dind で検証する構成では、毎タスクが固有名のタグ付きイメージ(~2GB)とボリュームを作り、
#   timeout/crash で漏れて累積→dind 満杯→docker 激遅→タイムアウト、を踏む。境界で回収して断つ。
#   driver は中身を知らない＝docker 知識はこの値だけに閉じる。dind 不使用の target は空でよい。
# BETWEEN_TASKS_CMD: >-
#   docker ps -aq | xargs -r docker rm -f;
#   docker image prune -af;
#   docker volume prune -f;
#   docker builder prune -f --keep-storage 3GB

# ── claude のモデル / effort ──
ANTHROPIC_MODEL: claude-sonnet-4-6   # 難所中心の対象だけ claude-opus-4-8 に
EFFORT_LEVEL: medium                 # low/medium/high/xhigh/max/auto（空=claudeの既定）

# ── commit identity ──
GIT_USER_NAME: loop-bot
GIT_USER_EMAIL: loop-bot@users.noreply.github.com

# ── Remote Control（スマホ/claude.ai から閲覧。空で無効）──
REMOTE_CONTROL_NAME: looptrooper

# ── ポーラーの有効/無効（全トリガ opt-in）──
#   本体の既定は全て false ＝何もしない素の箱。使うトリガだけここで true にする。
#   最低でも poll-gh（issue 取得＝主入力）を on にしないと箱は何も拾わない。
ENABLE_POLL_GH: true        # issue 取得（主入力。これが無いと何も始まらない）
ENABLE_POLL_PR: true        # PR レビュー指摘取得（主入力）
ENABLE_POLL_OUTCOME: true   # マージ後アウトカム観測
# ENABLE_POLL_SPEC: true    # spec/ からフェーズ毎に issue 群を自律分解（要 spec/）
# ENABLE_POLL_DEPS: true    # 依存脆弱性 → 起票（※パーサは npm audit 形式前提。非 npm なら no-op）
# ENABLE_POLL_CI: true      # main の CI 失敗 → 起票（要 CI_WORKFLOW）

# ── ポーラーの実行スケジュール（cron 書式。空=既定間隔 POLL_GH_INTERVAL ごと）──
#   標準5フィールド「分 時 日 月 曜」（曜 0-6, 0=日）。* / a-b / a,b / */s 対応。cron デーモン不要。
# POLL_GH_CRON: "*/5 * * * *"     # issue を5分毎に拾う
# POLL_PR_CRON: "*/10 * * * *"    # PR レビューを10分毎
# POLL_DEPS_CRON: "0 3 * * *"     # 依存監査は毎日3時
# POLL_CI_CRON: "0 9 * * 1-5"     # CI 失敗チェックは平日9時
# POLL_OUTCOME_CRON: "0 */4 * * *" # 4時間毎
# POLL_TICK: 60                   # 基底起床間隔秒（cron は分粒度なので60s以下推奨。既定60）

# ── 依存脆弱性の自動起票（実行頻度は上の POLL_DEPS_CRON で。既定 毎日3時）──
AUDIT_CMD: npm audit --json
DEPS_MAX_PER_RUN: 2

# ── main の CI 失敗を起票（GitHub Actions の結果受信）──
# CI_WORKFLOW: e2e.yaml      # 監視するワークフロー名 or ファイル名。空=無効
CI_BRANCH: main
CI_ISSUE_LABEL: loop:proposed
CI_ISSUE_LONG: true         # 起票時に loop:long も付ける（CI修正は長くなりがち）

# ── タイミング（必要なら上書き。既定で十分なら省略可）──
# TASK_TIMEOUT: 1200         # チェックポイントまでの待ち秒（既定20分）
# TASK_TIMEOUT_LONG: 3600    # loop:long の issue 用（既定60分）
# POLL_GH_INTERVAL: 900      # ポーラー巡回間隔秒（既定15分）
# ISSUE_SETTLE_SECS: 180     # 新規 issue の配線待ち猶予
# USAGE_BACKOFF: 1800        # usage limit 時のバックオフ秒
