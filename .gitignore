# ループの実行時状態（本体は container/app/ 配下）
container/app/.loop/queue/*
container/app/.loop/processed/*
container/app/.loop/blocked/*
container/app/.loop/results/*
container/app/.loop/done/*
container/app/.loop/logs/*
container/app/.loop/state/*
container/app/.loop/awaiting/*
container/app/.loop/memory/*
container/app/.loop/outcomes/*
!container/app/.loop/**/.gitkeep

# デプロイ固有の設定（雛形 container/config/loop.yaml.example は追跡・実体は gitignore）
container/config/loop.yaml

# 艦隊運用の実行時データ（~/.looptrooper 配下が既定。リポジトリ内に置いた場合の保険）
projects/

# 認証情報は絶対に置かない
.env
*.token
*.pem
claude-home/
container/app/.loop/.gh-token
container/app/.loop/.gh-installation-id
