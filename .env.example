# cp .env.example .env して「秘密」だけ埋める。.env は gitignore 済み（コミット禁止）。
# docker-compose.yml の env_file: .env で、これらがコンテナに注入される。
#
# ★ 設定の分担:
#   ・秘密（認証鍵・webhook 等）→ この .env
#   ・非秘密の設定（対象 repo / コマンド / モデル / ポーラー / スケジュール 等）→ loop.yaml（loop.yaml.example 参照）
#   優先順位: .env（ここ）> loop.yaml > 既定。＝ここに置けば緊急上書きにもなる。

# ── 認証: (A) GitHub App か (B) 静的トークン のどちらか。bin/gh-token.sh が両対応 ──
#   (A) GitHub App（推奨）── 短命 installation token を自動発行・ローテーション。bot として人間と区別できる。
#       App を作成 → 対象 repo に install（権限 Contents:RW / Pull requests:RW / Issues:RW / Metadata:R）。
#       秘密鍵 PEM は base64 1行にして B64 に貼る:
#         Linux : base64 -w0 app.private-key.pem
#         macOS : base64 -i app.private-key.pem | tr -d '\n'
#       INSTALLATION_ID は通常空でOK（対象 repo から自動解決）。
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_B64=
# GITHUB_APP_PRIVATE_KEY_FILE=/work/secrets/app.pem   # B64 の代わりに PEM ファイルをマウントする場合
# GITHUB_APP_INSTALLATION_ID=

#   (B) 静的トークン（PAT / machine user）── App 系が未設定のときだけ使われる。
#       repo単位 fine-grained PAT（Contents:RW / Pull requests:RW / Issues:RW / Metadata:R）。
# GH_TOKEN=github_pat_xxxxxxxx

# ── 通知（任意。Slack Incoming Webhook URL を入れると有効化。未設定ならログのみ）──
#   Discord 等にしたい場合は NOTIFY_CMD を直接上書き（明示指定が優先される）:
#   NOTIFY_CMD=jq -Rsa "{content: .}" | curl -s -H "Content-type: application/json" -d @- "<discord webhook url>"
SLACK_WEBHOOK_URL=
# NOTIFY_CMD=

# ── タイムゾーン（OS 環境変数として効かせるため .env に置く。loop.yaml の "HH:MM" もこの基準）──
TZ=Asia/Tokyo
