# cp .env.example .env して認証（GitHub App か GH_TOKEN）と対象の値を埋める。.env は gitignore 済み（コミット禁止）。
# docker-compose.yml の env_file: .env で、これらが丸ごとコンテナに注入される。

# ── 対象リポジトリ（HTTPS。token 認証なので SSH ではない）──
TARGET_REPO_URL=https://github.com/xxxx/xxxx.git

# ── PR の向き先（任意。未設定なら main）。develop 等に向けたい時に設定 ──
#   作業ブランチ loop/<id> もこの base から切られ、PR はここへ向く。
# PR_BASE_BRANCH=develop

# ── スタックコマンド（Verifier が回す。Claude セッションに $TEST_CMD 等で継承される）──
BUILD_CMD=npm run build
TEST_CMD=npm test
LINT_CMD=npm run lint

# ── main の CI 失敗を起票（任意。poll-ci.sh が GitHub Actions の結果を観測）──
#   重いテスト（e2e 等）は自前で回さず、main の CI が失敗したら issue を起票する。
#   CI_WORKFLOW に監視対象のワークフロー名 or ファイル名を入れると有効化。空＝無効（既定オフ）。
#   既定で loop:proposed 起票（人間が loop を付けたら修正が走る）。即修正なら CI_ISSUE_LABEL=loop。
# CI_WORKFLOW=e2e.yml
# CI_BRANCH=main
# CI_ISSUE_LABEL=loop:proposed
# CI_ISSUE_LONG=true   # CI修正は長くなりがちなので起票時に loop:long も付ける（timeout由来の再実行を避ける）

# ── claude のモデル（任意。未設定なら config.sh の既定 claude-sonnet-4-6）──
#   無人ループは長時間・多タスクなので既定は Sonnet（速い・サブスク枠が保つ）。
#   難所中心の対象だけ Opus に上書き: ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── effort（任意。claude の thinking 量＝トークン消費。未設定なら config.sh の既定 medium）──
#   無人の定型保守は high が過剰なので medium 推奨。難所中心なら high。空にすると claude の既定。
# EFFORT_LEVEL=medium

# ── Remote Control（任意。claude セッションをスマホ/claude.ai/code から閲覧・操作）──
#   非空ならその名前で有効化。空にすると無効。アウトバウンドのみ（inbound ポート不要）。
#   既定 looptrooper。無効化したいときだけ空に: REMOTE_CONTROL_NAME=
# REMOTE_CONTROL_NAME=looptrooper

# ── commit identity（任意。未設定なら config.sh の既定 loop-bot が使われる）──
#   App の bot 名義でコミットさせたい場合は bot のユーザーIDを調べて設定:
#     gh api users/<app-slug>[bot] --jq .id
#     GIT_USER_NAME=<app-slug>[bot]
#     GIT_USER_EMAIL=<id>+<app-slug>[bot]@users.noreply.github.com
GIT_USER_NAME=loop-bot
GIT_USER_EMAIL=loop-bot@users.noreply.github.com

# ── 認証: (A) GitHub App か (B) 静的トークン のどちらか。bin/gh-token.sh が両対応 ──
#   (A) GitHub App（推奨）── 短命 installation token を自動発行・ローテーション。bot として人間と区別できる。
#       App を作成 → 対象 repo に install（権限 Contents:RW / Pull requests:RW / Issues:RW / Metadata:R）。
#       秘密鍵 PEM は base64 1行にして B64 に貼る:
#         Linux : base64 -w0 app.private-key.pem
#         macOS : base64 -i app.private-key.pem | tr -d '\n'
#       INSTALLATION_ID は通常空でOK（対象 repo から自動解決）。
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_B64=
# GITHUB_APP_PRIVATE_KEY_FILE=/work/secrets/app.pem   # B64 の代わりに PEM ファイルをマウントする場合
# GITHUB_APP_INSTALLATION_ID=

#   (B) 静的トークン（PAT / machine user）── App 系が未設定のときだけ使われる。
#       repo単位 fine-grained PAT（Contents:RW / Pull requests:RW / Issues:RW / Metadata:R）。
# GH_TOKEN=github_pat_xxxxxxxx

# ── 通知（任意。Slack Incoming Webhook URL を入れると有効化。未設定ならログのみ）──
#   config.sh が stdin を jq で {"text": ...} に整形して POST する。
#   Discord 等にしたい場合は NOTIFY_CMD を直接上書き（明示指定が優先される）:
#   NOTIFY_CMD=jq -Rsa "{content: .}" | curl -s -H "Content-type: application/json" -d @- "<discord webhook url>"
SLACK_WEBHOOK_URL=

# ── ポーラーの実行スケジュール（任意・ポーラー毎）──
#   空＝従来どおり毎巡回（間隔ベース）。"HH:MM" を入れるとそのポーラーは毎日その時刻以降に1回だけ走る
#   （cron 不要。時刻は下の TZ 基準。粒度は巡回間隔）。主入力(GH/PR)は通常は空のまま、1日1回系向き。
# POLL_DEPS_AT=03:00
# POLL_CI_AT=09:00
# POLL_GH_AT=
# POLL_PR_AT=
# POLL_OUTCOME_AT=

# ── 任意 ──
TZ=Asia/Tokyo
